
<!DOCTYPE html>
<html lang="ko"><head><meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>2026년 6월에 반드시 외워야할 top tier 문제 모음</title>
<style>
:root{--bg:#fff;--fg:#1a1a1a;--muted:#6b7280;--line:#e5e7eb;--card:#f9fafb;--accent:#2563eb;--accent-bg:#dbeafe;
--star:#f59e0b;--green:#16a34a;--green-bg:#dcfce7;--red:#dc2626;--red-bg:#fee2e2;--rc:#7c3aed;--rc-bg:#ede9fe;--tc:#0891b2;--tc-bg:#cffafe;--sel:#fde68a;}
*{box-sizing:border-box}
body{margin:0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Malgun Gothic',sans-serif;background:var(--bg);color:var(--fg);line-height:1.55;font-size:15px;
-webkit-user-select:none;-moz-user-select:none;-ms-user-select:none;user-select:none;-webkit-touch-callout:none;}
input,textarea{-webkit-user-select:text;-moz-user-select:text;-ms-user-select:text;user-select:text;}
header{position:sticky;top:0;z-index:20;background:var(--bg);border-bottom:1px solid var(--line);padding:12px 16px 10px}
h1{font-size:17px;margin:0 0 2px}.sub{font-size:12px;color:var(--muted);margin-bottom:10px}
.controls{display:flex;flex-wrap:wrap;gap:8px;align-items:center}
#search{flex:1 1 220px;min-width:0;padding:8px 12px;border:1px solid var(--line);border-radius:8px;font-size:14px;outline:none}
#search:focus{border-color:var(--accent)}
.seg{display:inline-flex;border:1px solid var(--line);border-radius:8px;overflow:hidden}
.seg button{border:0;background:var(--bg);padding:7px 12px;font-size:13px;cursor:pointer;color:var(--fg)}
.seg button.on{background:var(--accent);color:#fff}
.tierbar{display:flex;flex-wrap:wrap;gap:6px;margin-top:8px}
.tchip{border:1px solid var(--line);border-radius:999px;padding:5px 11px;font-size:13px;cursor:pointer;background:var(--bg);white-space:nowrap}
.tchip.on{background:var(--star);border-color:var(--star);color:#fff;font-weight:600}
.toggle{display:flex;align-items:center;gap:6px;font-size:13px;color:var(--muted);cursor:pointer;user-select:none}
.count{font-size:12px;color:var(--muted);margin-top:8px}
main{padding:8px 16px 80px;max-width:900px;margin:0 auto}
.tierhead{display:flex;align-items:center;gap:8px;margin:22px 0 8px;padding-bottom:4px;border-bottom:2px solid var(--star)}
.tierhead .stars{color:var(--star);font-size:18px;letter-spacing:1px}.tierhead .lbl{font-weight:700}.tierhead .n{font-size:12px;color:var(--muted)}
.subhead{display:flex;align-items:center;gap:8px;margin:18px 0 4px;font-weight:600;font-size:14px;color:var(--fg)}.subhead .n{font-size:12px;color:var(--muted);font-weight:400}
.q{border:1px solid var(--line);border-radius:10px;padding:13px 15px;margin:10px 0;background:var(--card)}
.qhead{display:flex;align-items:center;gap:8px;margin-bottom:7px;flex-wrap:wrap}
.qid{font-weight:700;font-size:15px}.badge{font-size:11px;padding:2px 8px;border-radius:999px;font-weight:600}
.b-rc{background:var(--rc-bg);color:var(--rc)}.b-tc{background:var(--tc-bg);color:var(--tc)}.b-vol{background:var(--accent-bg);color:var(--accent)}
.qstars{color:var(--star);font-size:13px;margin-left:auto}
.passage{margin:6px 0}
.sent{cursor:default}
.selmode .sent{cursor:pointer;border-radius:3px;padding:0 1px}
.selmode .sent:hover{background:#f1f5f9}
.sent.picked{background:#cbd5e1}
.sent.correct{background:var(--green-bg);box-shadow:inset 0 -2px 0 var(--green)}
.sent.wrongpick{background:var(--red-bg);box-shadow:inset 0 -2px 0 var(--red);text-decoration:underline wavy var(--red)}
.qblock{margin:12px 0 0;padding-top:8px;border-top:1px dashed var(--line)}
.instr{font-style:italic;color:var(--muted);font-size:13px;margin:2px 0}
.stem{margin:4px 0;font-weight:500}
.qnum{font-weight:700;color:var(--accent);margin-right:2px}
.choices{margin:6px 0 0;padding:0;list-style:none}
.choices li{padding:5px 9px;margin:3px 0;border:1px solid var(--line);border-radius:7px;cursor:pointer;background:#fff;display:flex;gap:8px;align-items:flex-start}
.choices li:hover{border-color:var(--accent)}
.choices li .ltr{font-weight:700;flex:0 0 auto;min-width:16px}
.choices li.correct{background:var(--green-bg);border-color:var(--green)}
.choices li.wrong{background:var(--red-bg);border-color:var(--red)}
.choices li.box .ltr{display:none}
.choices li .bx{width:13px;height:13px;border:1px solid #9ca3af;border-radius:2px;margin-top:3px;flex:0 0 auto}
.choices li.correct .bx{background:var(--green);border-color:var(--green)}
table.grid{border-collapse:collapse;margin:8px 0;width:100%;max-width:560px}
table.grid th,table.grid td{border:1px solid #cbd5e1;padding:5px 9px;font-size:13.5px;text-align:left;vertical-align:top;cursor:pointer}
table.grid th{background:#f1f5f9;font-weight:600;cursor:default}
table.grid td:hover{background:#eef2ff}
table.grid td.correct{background:var(--green-bg);font-weight:600}
table.grid td.wrong{background:var(--red-bg)}
.qa{margin-top:7px;padding:7px 11px;border-radius:7px;background:var(--green-bg);color:#065f46;font-size:13.5px;display:none}
.qa.show{display:block}.qa b{color:var(--green)}
.qbtn{margin-top:7px;border:1px solid var(--line);background:#fff;border-radius:6px;padding:4px 10px;font-size:12.5px;cursor:pointer;color:var(--accent)}
.empty{text-align:center;color:var(--muted);padding:40px 0}
mark{background:#fde68a;padding:0 1px;border-radius:2px}
.hl{background:#fff59d;font-weight:700;padding:0 1px;border-radius:2px}
@media(max-width:480px){body{font-size:14px}}
</style></head><body>
<header>
<h1>2026년 6월에 반드시 외워야할 top tier 문제 모음</h1>
<div class="sub">감으로 찍어주는 적중이 아니니 통계와 데이터로 송종옥 선생님이 알려주는 빈출 문제</div>
<div class="controls">
<input id="search" placeholder="번호(예: 2496) 또는 단어 검색…" autocomplete="off">
<div class="seg" id="subjseg"><button data-s="ALL" class="on">전체</button><button data-s="RCCR">RCCR</button><button data-s="TCSE">TCSE</button></div>
<label class="toggle"><input type="checkbox" id="ansall"> 정답 모두 보기</label>
</div>
<div class="count" id="count"></div>
</header>
<main id="main"></main>
<script>
var __k=[90,55,156,225,66,184,111,19,212,40,145,126,172,85,3,246];function __dec(s){var b=atob(s),n=b.length,a=new Uint8Array(n);for(var i=0;i<n;i++){a[i]=b.charCodeAt(i)^__k[i%__k.length];}return new TextDecoder("utf-8").decode(a);}const DATA=JSON.parse(__dec(""));
const dec=s=>{const t=document.createElement('textarea');t.innerHTML=s==null?'':s;return t.value;};
let curSubj="ALL",curTier=5,curQuery="",showAll=false;
const stars=n=>'★'.repeat(n);
function hl(t){if(!curQuery)return t;const q=curQuery.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');try{return t.replace(new RegExp('('+q+')','gi'),'<mark>$1</mark>');}catch(e){return t;}}
function letters(ans){return (ans.match(/[A-F]/g)||[]);}
function matchQ(it){
  if(!curQuery)return true;const q=curQuery.toLowerCase();
  if((it.subject+' '+it.id).toLowerCase().includes(q)||String(it.id).includes(q))return true;
  let blob='';
  if(it.subject==='RCCR'){blob=(it.passage_sentences||[]).join(' ')+' '+(it.questions||[]).map(x=>(x.stem||'')+' '+x.choices.join(' ')).join(' ');}
  else{blob=(it.stem||[]).join(' ')+' '+(it.choices||[]).join(' ');if(it.grid)blob+=' '+it.grid.headers.join(' ')+' '+it.grid.rows.flat().join(' ');}
  return dec(blob).toLowerCase().includes(q);
}
// ---------- RC rendering ----------
function escHtml(t){return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function markHi(decoded,subs){
  if(!subs||!subs.length)return hl(decoded);
  // Build a single alternation regex from the cleaned substrings; wrap matches in <span class="hl">.
  const esc=s=>s.replace(/[.*+?^${}()|[\]\\]/g,'\\$&');
  const pat=subs.slice().sort((a,b)=>b.length-a.length).map(esc).join('|');
  let re;try{re=new RegExp('('+pat+')','g');}catch(e){return hl(decoded);}
  let res='',last=0,m;
  while((m=re.exec(decoded))!==null){
    res+=hl(decoded.slice(last,m.index));
    res+='<span class="hl">'+hl(m[0])+'</span>';
    last=m.index+m[0].length;
    if(m.index===re.lastIndex)re.lastIndex++;
  }
  res+=hl(decoded.slice(last));
  return res;
}
function rcCard(it){
  const id=it.subject+'-'+it.id;
  const hiMap=it.hi||{};
  let sents=(it.passage_sentences||[]).map((s,i)=>`<span class="sent" data-i="${i}" onclick="pickSent('${id}',${i})">${markHi(dec(s),hiMap[i])} </span>`).join('');
  let qhtml=it.questions.map((q,qi)=>renderRCQ(id,qi,q)).join('');
  return `<div class="q" id="q-${id}" data-id="${id}">
    <div class="qhead"><span class="qid">${it.subject} ${it.id}</span><span class="badge b-rc">RCCR</span><span class="badge b-vol">Vol ${it.vol}·G${it.group}</span><span class="qstars">${stars(it.tier)}</span></div>
    <div class="passage" id="psg-${id}">${sents}</div>${qhtml}</div>`;
}
function stripQNum(s){return s.replace(/^\s*\d+\s*[.\．·:]\s*/,'');}
function renderRCQ(id,qi,q){
  const qid=id+'-'+qi;
  let h=`<div class="qblock" data-q="${qid}">`;
  if(q.instr) h+=`<div class="instr">${hl(dec(q.instr))}</div>`;
  if(q.stem) h+=`<div class="stem"><span class="qnum">${qi+1}.</span> ${hl(stripQNum(dec(q.stem)))}</div>`;
  if(q.type==='select'){
    h+=`<div class="instr" style="color:var(--accent)">↑ 본문에서 문장을 클릭하세요</div>`;
    const ans=q.answer?`<div class="qa" id="qa-${qid}"><b>정답 문장</b> 위 본문에 초록색으로 표시됩니다.</div>`:'';
    h+=`<button class="qbtn" onclick="showSelect('${id}',${qi})">정답 문장 보기</button>${ans}`;
  }else{
    h+='<ul class="choices">'+q.choices.map(c=>{
      const L=dec(c).trim()[0];
      return `<li onclick="pickChoice(this,'${qid}','${L}')"><span class="ltr">${L}</span><span>${hl(dec(c).replace(/^[A-E][.\．·]\s*/,''))}</span></li>`;
    }).join('')+'</ul>';
    const ans=q.answer?`<div class="qa" id="qa-${qid}"><b>정답</b> &nbsp;${dec(q.answer)}</div>`:`<span class="qbtn" style="color:var(--muted);cursor:default">정답 미제공</span>`;
    if(q.answer) h+=`<button class="qbtn" onclick="toggleQA('${qid}')">정답 보기</button>${ans}`;
    else h+=ans;
  }
  h+=`</div>`;
  return h;
}
// ---------- TCSE rendering ----------
function tcCard(it){
  const id=it.subject+'-'+it.id;
  let h=`<div class="q" id="q-${id}"><div class="qhead"><span class="qid">${it.subject} ${it.id}</span><span class="badge b-tc">TCSE</span><span class="badge b-vol">Vol ${it.vol}·G${it.group}</span><span class="qstars">${stars(it.tier)}</span></div>`;
  (it.stem||[]).forEach(s=>h+=`<div class="stem" style="font-weight:400">${hl(dec(s))}</div>`);
  if(it.kind==='tc_grid'&&it.grid){
    h+='<table class="grid"><thead><tr>'+it.grid.headers.map(x=>`<th>${hl(dec(x))}</th>`).join('')+'</tr></thead><tbody>';
    it.grid.rows.forEach(r=>{h+='<tr>'+r.map(x=>`<td onclick="pickCell(this)">${hl(dec(x))}</td>`).join('')+'</tr>';});
    h+='</tbody></table>';
  }else{
    h+='<ul class="choices">'+(it.choices||[]).map(c=>`<li class="box" onclick="pickBox(this)"><span class="bx"></span><span>${hl(dec(c))}</span></li>`).join('')+'</ul>';
  }
  const ans=it.answer?`<div class="qa" id="qa-${id}"><b>정답</b> &nbsp;${dec(it.answer)}</div>`:`<span class="qbtn" style="color:var(--muted);cursor:default">정답 미제공</span>`;
  if(it.answer)h+=`<button class="qbtn" onclick="toggleQA('${id}')">정답 보기</button>${ans}`;else h+=ans;
  h+=`</div>`;return h;
}
// ---------- interactions ----------
const ITEM=id=>DATA.find(d=>(d.subject+'-'+d.id)===id);
function pickChoice(el,qid,L){
  const parts=qid.split('-');const it=ITEM(parts[0]+'-'+parts[1]);const q=it.questions[+parts[2]];
  if(!q.answer)return; const correct=letters(q.answer);
  el.classList.remove('correct','wrong');
  if(correct.includes(L)) el.classList.add('correct'); else el.classList.add('wrong');
}
function pickBox(el){
  const li=el; const card=li.closest('.q'); const it=ITEM(card.id.slice(2));
  if(!it.answer)return; const correct=letters(it.answer);
  const txt=li.innerText.trim(); // match by word against answer text
  const ansText=dec(it.answer).toLowerCase();
  const word=txt.toLowerCase();
  li.classList.remove('correct','wrong');
  if(ansText.includes(word)&&word.length>1) li.classList.add('correct'); else li.classList.add('wrong');
}
function pickCell(td){
  const card=td.closest('.q'); const it=ITEM(card.id.slice(2));
  if(!it.answer)return; const ansText=dec(it.answer).toLowerCase();
  const w=td.innerText.trim().toLowerCase();
  td.classList.remove('correct','wrong');
  if(w&&ansText.includes(w)) td.classList.add('correct'); else td.classList.add('wrong');
}
function pickSent(id,i){
  const it=ITEM(id); const psg=document.getElementById('psg-'+id);
  psg.classList.add('selmode');
  psg.querySelectorAll('.sent').forEach(s=>s.classList.remove('picked'));
  const el=psg.querySelector('.sent[data-i="'+i+'"]'); el.classList.add('picked');
  // check against any select question's idx
  const sel=it.questions.find(q=>q.type==='select');
  if(sel&&sel.select_idx>=0){
    el.classList.remove('picked');
    if(i===sel.select_idx) el.classList.add('correct'); else el.classList.add('wrongpick');
  }
}
function showSelect(id,qi){
  const it=ITEM(id); const q=it.questions[qi]; const psg=document.getElementById('psg-'+id);
  psg.querySelectorAll('.sent').forEach(s=>s.classList.remove('correct','wrongpick','picked'));
  if(q.select_idx>=0){ const el=psg.querySelector('.sent[data-i="'+q.select_idx+'"]'); if(el)el.classList.add('correct'); }
  const qa=document.getElementById('qa-'+id+'-'+qi); if(qa)qa.classList.add('show');
}
function toggleQA(key){const el=document.getElementById('qa-'+key);if(el)el.classList.toggle('show');}
// reveal-all behavior
function revealAll(on){
  document.querySelectorAll('.qa').forEach(e=>e.classList.toggle('show',on));
  if(on){
    DATA.forEach(it=>{
      if(it.subject==='RCCR'){
        const id=it.subject+'-'+it.id;
        it.questions.forEach(q=>{ if(q.type==='select'&&q.select_idx>=0){const psg=document.getElementById('psg-'+id);if(psg){const el=psg.querySelector('.sent[data-i="'+q.select_idx+'"]');if(el)el.classList.add('correct');}}});
      }
    });
  }else{ document.querySelectorAll('.sent.correct').forEach(e=>e.classList.remove('correct')); }
}
function render(){
  const main=document.getElementById('main');
  let items=DATA.filter(it=>(curSubj==='ALL'||it.subject===curSubj)&&matchQ(it));
  document.getElementById('count').textContent=`${items.length}문제 표시 중 (최고빈출 ★★★★★ 전체 ${DATA.length})`;
  if(!items.length){main.innerHTML='<div class="empty">조건에 맞는 문제가 없습니다.</div>';return;}
  const rc=items.filter(it=>it.subject==='RCCR');
  const tc=items.filter(it=>it.subject==='TCSE');
  let html=`<div class="tierhead"><span class="stars">★★★★★</span><span class="lbl">최고빈출 Top Tier</span><span class="n">${items.length}문제</span></div>`;
  if(rc.length){
    html+=`<div class="subhead"><span class="badge b-rc">RCCR</span> 독해 <span class="n">${rc.length}문제</span></div>`;
    html+=rc.map(rcCard).join('');
  }
  if(tc.length){
    html+=`<div class="subhead"><span class="badge b-tc">TCSE</span> 문장완성 <span class="n">${tc.length}문제</span></div>`;
    html+=tc.map(tcCard).join('');
  }
  main.innerHTML=html;
  if(showAll)revealAll(true);
}
document.getElementById('search').addEventListener('input',e=>{curQuery=e.target.value.trim();render();});
document.querySelectorAll('#subjseg button').forEach(b=>b.addEventListener('click',()=>{document.querySelectorAll('#subjseg button').forEach(x=>x.classList.remove('on'));b.classList.add('on');curSubj=b.dataset.s;render();}));
document.querySelectorAll('#tierbar .tchip').forEach(c=>c.addEventListener('click',()=>{document.querySelectorAll('#tierbar .tchip').forEach(x=>x.classList.remove('on'));c.classList.add('on');curTier=c.dataset.t;render();}));
document.getElementById('ansall').addEventListener('change',e=>{showAll=e.target.checked;render();});
render();

/* ---- content protection ---- */
(function(){
  var stop=function(e){e.preventDefault();e.stopPropagation();return false;};
  ['contextmenu','copy','cut','dragstart'].forEach(function(ev){document.addEventListener(ev,stop,{capture:true});});
  document.addEventListener('selectstart',function(e){var t=e.target;if(t&&(t.tagName==='INPUT'||t.tagName==='TEXTAREA'))return;return stop(e);},{capture:true});
  document.addEventListener('keydown',function(e){
    var k=(e.key||'').toLowerCase();
    // F12
    if(e.keyCode===123||k==='f12'){return stop(e);}
    // Ctrl/Cmd+U (view source)
    if((e.ctrlKey||e.metaKey)&&k==='u'){return stop(e);}
    // Ctrl/Cmd+S (save)
    if((e.ctrlKey||e.metaKey)&&k==='s'){return stop(e);}
    // Ctrl/Cmd+P (print)
    if((e.ctrlKey||e.metaKey)&&k==='p'){return stop(e);}
    // DevTools: Ctrl/Cmd+Shift+ I/J/C/K  (and Cmd+Opt on mac)
    if((e.ctrlKey||e.metaKey)&&(e.shiftKey||e.altKey)&&(k==='i'||k==='j'||k==='c'||k==='k')){return stop(e);}
    // Ctrl/Cmd+A select-all outside inputs
    if((e.ctrlKey||e.metaKey)&&k==='a'){var t=e.target;if(!(t&&(t.tagName==='INPUT'||t.tagName==='TEXTAREA')))return stop(e);}
  },{capture:true});
})();
</script></body></html>
